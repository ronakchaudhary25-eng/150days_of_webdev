    <title>Document</title>
    <style>
      .Name {
        text-align: center;
      }

      .L {
        font-family: "Times New Roman", Times, serif;
        font-style: italic;
        font-size: 30px;
        font-weight: bold;
        line-height: 25px;
        color: rgb(201, 30, 30);
        letter-spacing: 5px;
        display: inline-block;
        border: 2px solid purple;
      }

      h1 {
        font-family: "Times New Roman", Times, serif;

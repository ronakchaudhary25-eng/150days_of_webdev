<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Css Box model </title>
    <style>

        .box {
            background-color: rgb(30, 158, 201);
            /* border: 2px solid rgb(19, 17, 17); */
        }
        .box1 {
            /* background-color: rgb(30, 158, 201); */
            padding: 10px;
            color: rgb(19, 17, 17);
            border : 5px solid rgba(224, 100, 32, 0.556);
            height : 100px;
            box-sizing: border-box;
            margin : 25px;
        }
        .box2 {
            /* background-color: rgb(201, 118, 30); */
            padding: 10px;
            color: rgb(19, 17, 17);
            border: 5px solid #0fdf70bc; 
            height : 100px;
            box-sizing: border-box;
            margin : 35px;
        }

    </style>
</head>
<body>
    <!-- margin collapse and box sizzing border box concepts -->


    <div class="box box1">
        <h3>Box 1</h3>
        <p>This is the content of Box 1.</p>
    </div>

    <div class="box box2">
        <h3>Box 2</h3>
        <p>This is the content of Box 2.</p>
    </div>
    
</body>
</html>
